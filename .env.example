# Puerto en el que corre la aplicación
PORT=3000

# URI de conexión a MongoDB
# Formato: mongodb://[usuario:contraseña@]host:puerto/nombre-base-datos
MONGODB_URI=mongodb://localhost:27017/products-management

# JWT Configuration
# Secret key para firmar tokens (cambiar en producción)
JWT_SECRET=tu-secreto-super-seguro-cambiame-en-produccion
# Tiempo de expiración del token (ej: 1d, 7d, 24h)
JWT_EXPIRES_IN=1d
